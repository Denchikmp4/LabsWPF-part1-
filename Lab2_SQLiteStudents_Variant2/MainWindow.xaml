<Window x:Class="Lab2_SQLiteStudents_Variant2.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="ЛР2. База данных студентов" Height="520" Width="820">
    <Grid Margin="12">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <GroupBox Header="Данные студента" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="150"/><ColumnDefinition Width="70"/><ColumnDefinition Width="220"/><ColumnDefinition Width="80"/><ColumnDefinition Width="80"/><ColumnDefinition Width="90"/><ColumnDefinition Width="80"/></Grid.ColumnDefinitions>
                <TextBlock Text="№" VerticalAlignment="Center"/><TextBox x:Name="IdBox" Grid.Column="1" Margin="4"/>
                <TextBlock Text="ФИО" Grid.Column="2" VerticalAlignment="Center"/><TextBox x:Name="NameBox" Grid.Column="3" Margin="4"/>
                <TextBlock Text="Физика" Grid.Column="4" VerticalAlignment="Center"/><TextBox x:Name="PhysicsBox" Grid.Column="5" Margin="4"/>
                <TextBlock Text="Матем." Grid.Column="6" VerticalAlignment="Center"/><TextBox x:Name="MathBox" Grid.Column="7" Margin="4"/>
                <TextBlock Text="Телефон" Grid.Row="1" VerticalAlignment="Center" Margin="0,8,0,0"/>
                <TextBox x:Name="PhoneBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="4,8,4,0"/>
            </Grid>
        </GroupBox>
        <DataGrid x:Name="StudentsGrid" Grid.Row="1" AutoGenerateColumns="False" SelectionChanged="StudentsGrid_SelectionChanged" Margin="0,12" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="180"/>
                <DataGridTextColumn Header="Физика" Binding="{Binding Physics}" Width="90"/>
                <DataGridTextColumn Header="Математика" Binding="{Binding Math}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Добавить" Width="110" Margin="5" Click="Add_Click"/>
            <Button Content="Обновить" Width="110" Margin="5" Click="Update_Click"/>
            <Button Content="Удалить" Width="110" Margin="5" Click="Delete_Click"/>
            <Button Content="Очистить" Width="110" Margin="5" Click="Clear_Click"/>
            <Button Content="Прочитать БД" Width="120" Margin="5" Click="Load_Click"/>
        </StackPanel>
    </Grid>
</Window>
