<Window x:Class="Lab1_1_Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ЛР1.1 Калькулятор" Height="260" Width="420">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/><ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="A" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="ABox" Grid.Column="1" Margin="0,0,0,8"/>
        <TextBlock Text="Б" Grid.Row="1" FontWeight="Bold" VerticalAlignment="Center"/>
        <TextBox x:Name="BBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8"/>
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8">
            <Button Content="+" Width="60" Margin="4" Click="Operation_Click"/>
            <Button Content="-" Width="60" Margin="4" Click="Operation_Click"/>
            <Button Content="*" Width="60" Margin="4" Click="Operation_Click"/>
            <Button Content="/" Width="60" Margin="4" Click="Operation_Click"/>
        </StackPanel>
        <TextBlock x:Name="ResultText" Grid.Row="3" Grid.ColumnSpan="2" Text="Результат:" FontSize="16" TextWrapping="Wrap" Margin="0,12,0,0"/>
    </Grid>
</Window>
