<Window x:Class="ChatClient.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="ЛР3. Клиент сетевого чата" Height="480" Width="680" Closing="Window_Closing">
    <Grid Margin="12">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Имя:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="NameBox" Width="140" Text="User1"/>
            <Button x:Name="ConnectButton" Content="Подключиться" Width="120" Margin="8,0" Click="Connect_Click"/>
            <Button x:Name="DisconnectButton" Content="Отключиться" Width="120" Click="Disconnect_Click" IsEnabled="False"/>
        </StackPanel>
        <ListBox x:Name="MessagesList" Grid.Row="1" Margin="0,12"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <TextBlock Text="Адресат:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="RecipientBox" Width="180"/>
            <TextBox x:Name="MessageBox" Width="330" Margin="8,0"/>
            <Button Content="Отправить" Width="110" Click="Send_Click"/>
        </StackPanel>
        <TextBlock Grid.Row="3" Text="Вариант 2: сообщение можно отправить всем адресатам сразу, выбрав 'Все'." Margin="0,10,0,0"/>
    </Grid>
</Window>
